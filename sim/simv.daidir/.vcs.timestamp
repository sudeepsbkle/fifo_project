BASH_FUNC_which%%=() {  ( alias;_ eval ${which_declare} ) | /usr/bin/which --tty-only --read-alias --read-functions --show-tilde --show-dot $@_}
BASH_FUNC_scl%%=() {  if [ "$1" = "load" -o "$1" = "unload" ]; then_ eval "module $@";_ else_ /usr/bin/scl "$@";_ fi_}
BASH_FUNC_module%%=() {  local _mlredir=1;_ if [ -n "${MODULES_REDIRECT_OUTPUT+x}" ]; then_ if [ "$MODULES_REDIRECT_OUTPUT" = '0' ]; then_ _mlredir=0;_ else_ if [ "$MODULES_REDIRECT_OUTPUT" = '1' ]; then_ _mlredir=1;_ fi;_ fi;_ fi;_ case " $@ " in _ *' --no-redirect '*)_ _mlredir=0_ ;;_ *' --redirect '*)_ _mlredir=1_ ;;_ esac;_ if [ $_mlredir -eq 0 ]; then_ _module_raw "$@";_ else_ _module_raw "$@" 2>&1;_ fi_}
BASH_FUNC_ml%%=() {  module ml "$@"_}
BASH_FUNC_eda-tools-info%%=() {  echo "";_ echo "════════════════════════════════════════════════════════════════════";_ echo "              INSTALLED EDA TOOLS & ENVIRONMENT                     ";_ echo "════════════════════════════════════════════════════════════════════";_ echo "";_ echo -e "${BLUE}CADENCE TOOLS (Analog IC Design):${NC}";_ if command -v virtuoso &> /dev/null; then_ echo "  virtuoso          - Schematic/Layout Editor";_ echo "                      ($(virtuoso -version 2>&1 | head -1 || echo 'IC 25.10'))";_ else_ echo "  virtuoso          - Not found in PATH";_ fi;_ if command -v spectre &> /dev/null; then_ echo "  spectre           - Circuit Simulator";_ else_ echo "  spectre           - Not found in PATH (may be invoked from Virtuoso)";_ fi;_ echo "  assura/calibre    - DRC/LVS Verification";_ echo "  quantus/starrc    - Parasitic Extraction";_ echo "";_ echo -e "${BLUE}SYNOPSYS TOOLS (Digital Design & Verification):${NC}";_ if command -v vcs &> /dev/null; then_ echo "  vcs               - Verilog Simulator";_ echo "                      ($(vcs -ID 2>&1 | grep Version || echo 'X-2025.06'))";_ fi;_ if command -v verdi &> /dev/null; then_ echo "  verdi             - Waveform Viewer & Debug";_ fi;_ if command -v dc_shell &> /dev/null; then_ echo "  dc_shell          - Design Compiler (Synthesis)";_ fi;_ if command -v icc2_shell &> /dev/null; then_ echo "  icc2_shell        - Physical Design (P&R)";_ fi;_ if command -v pt_shell &> /dev/null; then_ echo "  pt_shell          - PrimeTime (STA)";_ fi;_ if command -v fm_shell &> /dev/null; then_ echo "  fm_shell          - Formality (Formal Verification)";_ fi;_ if command -v spyglass &> /dev/null; then_ echo "  spyglass          - Lint & CDC Analysis";_ fi;_ echo "";_ echo -e "${BLUE}XILINX TOOLS (Vivado / Vitis):${NC}";_ if command -v vivado &> /dev/null; then_ echo "  vivado            - Vivado Design Suite 2025.2";_ else_ echo "  vivado            - Not found in PATH";_ fi;_ if command -v vitis &> /dev/null; then_ echo "  vitis             - Vitis Unified Software Platform";_ fi;_ if command -v vitis_hls &> /dev/null; then_ echo "  vitis_hls         - High-Level Synthesis";_ fi;_ echo "";_ echo -e "${BLUE}PDK (Process Design Kit):${NC}";_ if [ -n "$GF_PDK_HOME" ]; then_ echo "  Technology        - GlobalFoundries 130nm BCD";_ echo "  Version           - V1.0_5.1a";_ echo "  BEOL Stack        - $BEOL_STACK";_ echo "  Location          - $GF_PDK_HOME";_ echo "  Models            - $PDK_SPECTRE";_ else_ echo "  PDK not configured";_ fi;_ echo "";_ echo "════════════════════════════════════════════════════════════════════";_ echo ""_}
BASH_FUNC_eda-license-check%%=() {  echo "";_ echo "════════════════════════════════════════════════════════════════════";_ echo "              LICENSE SERVER CONNECTIVITY CHECK                     ";_ echo "════════════════════════════════════════════════════════════════════";_ echo "";_ echo -n "Cadence License (5280@14.139.1.126):    ";_ if timeout 2 bash -c "echo > /dev/tcp/14.139.1.126/5280" 2> /dev/null; then_ echo -e "${GREEN}✓ Connected${NC}";_ else_ echo -e "${RED}✗ Failed${NC}";_ fi;_ echo -n "Synopsys License (27020@14.139.1.126):  ";_ if timeout 2 bash -c "echo > /dev/tcp/14.139.1.126/27020" 2> /dev/null; then_ echo -e "${GREEN}✓ Connected${NC}";_ else_ echo -e "${RED}✗ Failed${NC}";_ fi;_ echo -n "Mentor License (1717@14.139.1.126):     ";_ if timeout 2 bash -c "echo > /dev/tcp/14.139.1.126/1717" 2> /dev/null; then_ echo -e "${GREEN}✓ Connected${NC}";_ else_ echo -e "${RED}✗ Failed${NC}";_ fi;_ echo -n "Xilinx License (49704@10.240.112.16):   ";_ if timeout 2 bash -c "echo > /dev/tcp/10.240.112.16/49704" 2> /dev/null; then_ echo -e "${GREEN}✓ Connected${NC}";_ else_ echo -e "${RED}✗ Failed${NC}";_ fi;_ echo "";_ echo "════════════════════════════════════════════════════════════════════";_ echo ""_}
BASH_FUNC_eda-info%%=() {  eda-tools-info_}
BASH_FUNC_eda-help%%=() {  echo "";_ echo "════════════════════════════════════════════════════════════════════";_ echo "                    QUICK TOOL REFERENCE                            ";_ echo "════════════════════════════════════════════════════════════════════";_ echo "";_ echo -e "${BLUE}ANALOG DESIGN (Cadence):${NC}";_ echo "  virtuoso &                    - Launch Virtuoso GUI";_ echo "  spectre <netlist.scs>         - Run Spectre simulation";_ echo "  viva <results.raw> &          - View waveforms";_ echo "";_ echo -e "${BLUE}DIGITAL SIMULATION (Synopsys):${NC}";_ echo "  vcs <files> -o simv           - Compile with VCS";_ echo "  ./simv                        - Run simulation";_ echo "  verdi &                       - Launch Verdi";_ echo "  verdi -ssf <file.fsdb> &      - View waveforms";_ echo "";_ echo -e "${BLUE}DIGITAL SYNTHESIS (Synopsys):${NC}";_ echo "  dc_shell                      - Launch Design Compiler";_ echo "  dc_shell -f script.tcl        - Run DC script";_ echo "";_ echo -e "${BLUE}PHYSICAL DESIGN (Synopsys):${NC}";_ echo "  icc2_shell                    - Launch ICC2";_ echo "  icc2_shell -f script.tcl      - Run ICC2 script";_ echo "";_ echo -e "${BLUE}TIMING ANALYSIS (Synopsys):${NC}";_ echo "  pt_shell                      - Launch PrimeTime";_ echo "";_ echo -e "${BLUE}XILINX TOOLS (Vivado / Vitis):${NC}";_ echo "  vivado &                      - Launch Vivado GUI";_ echo "  vivado -mode batch -source <script.tcl>  - Run Tcl script";_ echo "  vitis &                       - Launch Vitis IDE";_ echo "  vitis_hls &                   - Launch HLS GUI";_ echo "";_ echo -e "${BLUE}HELPER FUNCTIONS:${NC}";_ echo "  eda-tools-info                - Show all installed tools";_ echo "  eda-license-check             - Check license servers";_ echo "  eda-help                      - Show this help";_ echo "";_ echo "════════════════════════════════════════════════════════════════════";_ echo ""_}
BASH_FUNC__module_raw%%=() {  eval "$(/usr/bin/tclsh '/usr/share/Modules/libexec/modulecmd.tcl' bash "$@")";_ _mlstatus=$?;_ return $_mlstatus_}
ASSURA_HOME=/mnt/workspace/tools/cadence/ASSURA251
